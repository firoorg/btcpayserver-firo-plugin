@using BTCPayServer.Plugins.Firo.Configuration
@using BTCPayServer.Plugins.Firo.Controllers
@using BTCPayServer.Abstractions.Contracts
@inject SignInManager<ApplicationUser> SignInManager;
@inject FiroLikeConfiguration FiroLikeConfiguration;
@inject IScopeProvider ScopeProvider
@inject UIFiroLikeStoreController UiFiroLikeStore;
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
}
@if (SignInManager.IsSignedIn(User) && User.IsInRole(Roles.ServerAdmin) && FiroLikeConfiguration.FiroLikeConfigurationItems.Any())
{
    var store = Context.GetStoreData();
    var result = UiFiroLikeStore.GetVM(store);

    foreach (var item in result.Items)
    {
        var isActive = !string.IsNullOrEmpty(storeId) && ViewContext.RouteData.Values.TryGetValue("Controller", out var controller) && controller is not null &&
                       nameof(UIFiroLikeStoreController).StartsWith(controller.ToString() ?? string.Empty, StringComparison.InvariantCultureIgnoreCase) &&
                       ViewContext.RouteData.Values.TryGetValue("cryptoCode", out var cryptoCode) && cryptoCode is not null && cryptoCode.ToString() == item.CryptoCode;
        <li class="nav-item">
            <a class="nav-link @(isActive ? "active" : "")"
               asp-route-cryptoCode="@item.CryptoCode"
               asp-route-storeId="@storeId"
               asp-action="GetStoreFiroLikePaymentMethod"
               asp-controller="UIFiroLikeStore">
                <span class="me-2 btcpay-status btcpay-status--@(item.Enabled ? "enabled" : "pending")"></span>
                <span>@(item.CryptoCode == "FIRO" ? "Firo (Spark)" : item.CryptoCode)</span>
            </a>
        </li>
    }
}
