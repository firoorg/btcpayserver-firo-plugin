@using System.Globalization
@using BTCPayServer.Plugins.Firo.Payments
@using BTCPayServer.Plugins.Firo.Services
@using BTCPayServer.Plugins.Firo.ViewModels
@using BTCPayServer.Services
@using BTCPayServer.Services.Invoices
@inject DisplayFormatter DisplayFormatter
@model BTCPayServer.Models.InvoicingModels.InvoiceDetailsModel
@inject TransactionLinkProviders TransactionLinkProviders
@inject PaymentMethodHandlerDictionary handlers

@{
    var payments = Model.Payments.Select(payment =>
    {
        if (!handlers.TryGetValue(payment.PaymentMethodId, out var h) || h is not FiroLikePaymentMethodHandler handler)
            return null;
        var m = new FiroPaymentViewModel();
        var paymentData = handler.ParsePaymentDetails(payment.Details);
        m.PaymentMethodId = handler.PaymentMethodId;
        m.DepositAddress = payment.Destination;
        m.Amount = payment.Value.ToString(CultureInfo.InvariantCulture);
        m.InstantLocked = paymentData.InstantLocked;
        m.ChainLocked = paymentData.ChainLocked;

        var confReq = FiroListener.ConfirmationsRequired(paymentData, payment.InvoiceEntity.SpeedPolicy);
        var confCount = paymentData.ConfirmationCount;

        if (paymentData.InstantLocked && paymentData.ChainLocked)
        {
            m.LockStatus = "InstantSend + ChainLock";
            m.Confirmations = $"{confCount} (Locked)";
        }
        else if (paymentData.InstantLocked)
        {
            m.LockStatus = "InstantSend Locked";
            m.Confirmations = $"{confCount} (IS Locked)";
        }
        else if (paymentData.ChainLocked)
        {
            m.LockStatus = "ChainLocked";
            m.Confirmations = $"{confCount} (ChainLocked)";
        }
        else
        {
            m.LockStatus = "Unconfirmed";
            confCount = Math.Min(confReq, confCount);
            m.Confirmations = $"{confCount} / {confReq}";
        }

        m.TransactionId = paymentData.TransactionId;
        m.ReceivedTime = payment.ReceivedTime;
        if (paymentData.TransactionId != null)
            m.TransactionLink = TransactionLinkProviders.GetTransactionLink(m.PaymentMethodId, paymentData.TransactionId);
        m.Currency = payment.Currency;
        return m;
    }).Where(c => c != null).ToList();
}

@if (payments.Any())
{
    <section>
        <h5>Firo Spark Payments</h5>
        <table class="table table-hover">
            <thead>
            <tr>
                <th class="w-75px">Payment Method</th>
                <th class="w-175px">Destination</th>
                <th class="text-nowrap">Payment Proof</th>
                <th class="text-end">Confirmations</th>
                <th class="text-end">Lock Status</th>
                <th class="w-150px text-end">Paid</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var payment in payments)
            {
                <tr>
                    <td>@payment.PaymentMethodId</td>
                    <td><vc:truncate-center text="@payment.DepositAddress" classes="truncate-center-id" /></td>
                    <td><vc:truncate-center text="@payment.TransactionId" link="@payment.TransactionLink" classes="truncate-center-id" /></td>
                    <td class="text-end">@payment.Confirmations</td>
                    <td class="text-end">
                        @if (payment.InstantLocked || payment.ChainLocked)
                        {
                            <span class="text-success">@payment.LockStatus</span>
                        }
                        else
                        {
                            <span class="text-warning">@payment.LockStatus</span>
                        }
                    </td>
                    <td class="payment-value text-end text-nowrap">
                        <span data-sensitive class="text-success">@DisplayFormatter.Currency(payment.Amount, payment.Currency)</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
